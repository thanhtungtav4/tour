{
  "key": "group_tour_fields",
  "title": "Thông tin Tour",
  "fields": [
    {
      "key": "field_tour_price",
      "label": "Giá tour",
      "name": "price",
      "type": "number",
      "instructions": "Giá bán của tour (ví dụ: 450000)",
      "required": 1,
      "default_value": 0
    },
    {
      "key": "field_tour_difficulty",
      "label": "Độ khó",
      "name": "difficulty",
      "type": "select",
      "required": 1,
      "choices": {
        "easy": "Dễ",
        "medium": "Trung bình",
        "hard": "Khó"
      },
      "default_value": "easy"
    },
    {
      "key": "field_tour_duration",
      "label": "Thời lượng",
      "name": "duration",
      "type": "text",
      "instructions": "Ví dụ: 1 ngày hoặc 2 ngày 1 đêm",
      "required": 1,
      "default_value": "1 ngày"
    },
    {
      "key": "field_tour_departure_time",
      "label": "Thời gian khởi hành",
      "name": "departure_time",
      "type": "text",
      "instructions": "Ví dụ: Sáng hoặc Hệ thống",
      "required": 1,
      "default_value": "Sáng"
    },
    {
      "key": "field_tour_gallery",
      "label": "Thư viện ảnh (ACF Pro)",
      "name": "gallery",
      "type": "gallery",
      "instructions": "Chọn nhiều ảnh từ thư viện Media của WordPress",
      "required": 0,
      "return_format": "url",
      "preview_size": "medium",
      "insert": "append"
    },
    {
      "key": "field_tour_departure_dates",
      "label": "Các ngày khởi hành (ACF Pro Repeater)",
      "name": "departure_dates",
      "type": "repeater",
      "instructions": "Quản lý các ngày khởi hành và số chỗ trống tương ứng cho từng ngày",
      "required": 0,
      "collapsed": "field_tour_dep_date",
      "min": 0,
      "max": 0,
      "layout": "table",
      "button_label": "Thêm ngày khởi hành",
      "sub_fields": [
        {
          "key": "field_tour_dep_date",
          "label": "Ngày đi",
          "name": "date",
          "type": "date_picker",
          "required": 1,
          "display_format": "d/m/Y",
          "return_format": "Y-m-d"
        },
        {
          "key": "field_tour_dep_spots",
          "label": "Số chỗ trống",
          "name": "available_spots",
          "type": "number",
          "required": 1,
          "default_value": 15
        }
      ]
    },
    {
      "key": "field_tour_highlights",
      "label": "Điểm nổi bật",
      "name": "highlights",
      "type": "textarea",
      "instructions": "Mỗi điểm nổi bật nằm trên một dòng",
      "required": 0,
      "default_value": ""
    },
    {
      "key": "field_tour_itinerary",
      "label": "Lịch trình chi tiết (ACF Pro Repeater)",
      "name": "itinerary",
      "type": "repeater",
      "instructions": "Nhập lịch trình chi tiết theo từng mốc thời gian",
      "required": 0,
      "collapsed": "field_tour_itinerary_time",
      "min": 0,
      "max": 0,
      "layout": "row",
      "button_label": "Thêm mốc lịch trình",
      "sub_fields": [
        {
          "key": "field_tour_itinerary_time",
          "label": "Mốc thời gian",
          "name": "time",
          "type": "text",
          "instructions": "Ví dụ: 05:30 hoặc Ngày 1 - 08:00",
          "required": 1
        },
        {
          "key": "field_tour_itinerary_activity",
          "label": "Hoạt động",
          "name": "activity",
          "type": "textarea",
          "required": 1,
          "rows": 2
        }
      ]
    },
    {
      "key": "field_tour_included",
      "label": "Dịch vụ đã bao gồm",
      "name": "included",
      "type": "textarea",
      "instructions": "Mỗi dịch vụ nằm trên một dòng",
      "required": 0,
      "default_value": ""
    },
    {
      "key": "field_tour_excluded",
      "label": "Dịch vụ không bao gồm",
      "name": "excluded",
      "type": "textarea",
      "instructions": "Mỗi dịch vụ nằm trên một dòng",
      "required": 0,
      "default_value": ""
    },
    {
      "key": "field_tour_notes",
      "label": "Lưu ý quan trọng",
      "name": "notes",
      "type": "textarea",
      "instructions": "Các dặn dò hoặc chuẩn bị cần thiết cho chuyến đi",
      "required": 0,
      "default_value": ""
    }
  ],
  "location": [
    [
      {
        "param": "post_type",
        "operator": "==",
        "value": "tour"
      }
    ]
  ],
  "menu_order": 0,
  "position": "normal",
  "style": "default",
  "label_placement": "top",
  "instruction_placement": "label",
  "active": true
}
